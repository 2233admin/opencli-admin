# NAS 24×7 部署模板 — III 控制面 + ODP 数据面
# 路径: /volume1/docker/opencli-admin/
# 启动: docker compose --profile nas up -d --build

COMPOSE_PROJECT_NAME=opencli-admin
IMAGE_TAG=0.3.6

# 对外访问（LAN）
PUBLIC_URL=http://192.168.50.130:8031
API_PORT=8031
FRONTEND_PORT=8030
AGENT1_PORT=19823

# 采集编排：III 负责 cron；API 仅 UI + 手动触发
COLLECTION_ORCHESTRATOR=iii
COLLECTION_MODE=local
TASK_EXECUTOR=local

# Dify workflow 兼容 Sidecar（nas profile 自动包含；固定 Graphon 0.7.0）。
DIFY_GRAPHON_RUNTIME_URL=http://dify-graphon-runtime:8095
DIFY_GRAPHON_PORT=8095
DIFY_GRAPHON_MAX_REQUEST_BYTES=1048576
DIFY_GRAPHON_MAX_OUTPUT_BYTES=1048576
DIFY_GRAPHON_EXECUTION_TIMEOUT_SECONDS=120
DIFY_GRAPHON_MAX_CONCURRENT_RUNS=2
DIFY_GRAPHON_TMPFS_SIZE=64m
# 没有独立 Sandbox 时保持为空，code 节点会安全地标记为 blocked。
DIFY_SANDBOX_ENDPOINT=
DIFY_SANDBOX_API_KEY=
DIFY_GRAPHON_SLIM_PATH=

# 数据面 — Postgres + ODP ingest
DATABASE_URL=postgresql+asyncpg://opencli:opencli_secret@postgres:5432/opencli_admin
POSTGRES_DB=opencli_admin
POSTGRES_USER=opencli
POSTGRES_PASSWORD=change-me-in-production

ODP_INGEST_URL=http://odp-ingest:8040
III_URL=ws://iii-engine:49134
ODP_INGEST_PORT=8040
III_WS_PORT=49134

# agent-1：宿主机 Chrome + Bridge（B站/小红书/Twitter 登录态在 Chrome profile volume）
AGENT_MODE=bridge
OPENCLI_MODE=bridge
OPENCLI_DAEMON_PORT=19825
OPENCLI_TIMEOUT=120

# Discord 采集在 PC 边缘跑（discord-cli + DISCORD_TOKEN），指向 NAS III/ODP：
# III_URL=ws://192.168.50.130:49134
# ODP_INGEST_URL=http://192.168.50.130:8040

SECRET_KEY=change-me-in-production-use-long-random-string
DEBUG=false
APP_ENV=production
DEFAULT_TIMEZONE=Asia/Shanghai
