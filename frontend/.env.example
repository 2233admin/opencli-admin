# Browser OIDC client (Authorization Code + PKCE)
NEXT_PUBLIC_OIDC_AUTHORITY=https://identity.example.com
NEXT_PUBLIC_OIDC_CLIENT_ID=opencli-admin
NEXT_PUBLIC_OIDC_SCOPE=openid profile email

# Optional overrides. Defaults are /auth/callback and /login on this origin.
# NEXT_PUBLIC_OIDC_REDIRECT_URI=https://admin.example.com/auth/callback
# NEXT_PUBLIC_OIDC_POST_LOGOUT_REDIRECT_URI=https://admin.example.com/login

# Fleet transport credential. Prefer entering it at runtime on the login page
# unless this frontend is deployed only inside a trusted control-plane network.
# NEXT_PUBLIC_API_AUTH_TOKEN=

# Local development only; production builds never expose this bypass.
NEXT_PUBLIC_ALLOW_UNAUTHENTICATED_DEV=true
